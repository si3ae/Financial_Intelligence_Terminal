// Node tsconfig (build-tooling target).
//
// Covers files that run in Node rather than the browser — chiefly
// `vite.config.ts`. DOM libs are intentionally excluded and `strict` is on, so
// mistakes in build configuration surface immediately.
{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting — strict for build-tooling code. */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["vite.config.ts"]
}
