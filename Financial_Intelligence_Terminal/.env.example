# .env.example
#
# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and must never be committed.
#
# All values are available in your Supabase project dashboard:
#   https://supabase.com/dashboard/project/<your-project-id>/settings/api
#
# VITE_ prefix is required for Vite to expose these to the browser bundle.
# Do NOT store secret keys (NewsAPI, Alpha Vantage) here — those belong
# in Supabase Edge Function Secrets (Dashboard → Settings → Edge Functions).

VITE_SUPABASE_PROJECT_ID=your-project-id-here
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key-here
VITE_SUPABASE_URL=https://your-project-id-here.supabase.co
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
GEMINI_API_KEY=your_gemini_key_here
NEWS_API_KEY=your_key_here